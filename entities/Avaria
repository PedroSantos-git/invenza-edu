{
  "name": "Avaria",
  "type": "object",
  "properties": {
    "equipamento_id": {
      "type": "string"
    },
    "equipamento_info": {
      "type": "string",
      "description": "Info do equipamento (cache)"
    },
    "origem": {
      "type": "string",
      "enum": [
        "DEVOLU\u00c7\u00c3O",
        "DIRETA"
      ]
    },
    "devolucao_id": {
      "type": "string"
    },
    "estado": {
      "type": "string",
      "enum": [
        "A REVER",
        "DIAGNOSTICADO",
        "EM REPARA\u00c7\u00c3O",
        "AGUARDA PE\u00c7AS",
        "ARRANJADO",
        "INUTILIZADO"
      ],
      "default": "A REVER"
    },
    "diagnostico": {
      "type": "string"
    },
    "resolucao": {
      "type": "string"
    },
    "equipamento_com_problemas": {
      "type": "boolean",
      "default": false,
      "description": "Equipamento entregue com problemas (para atualizar o estado do empr\u00e9stimo)"
    },
    "data_resolucao": {
      "type": "string",
