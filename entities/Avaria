    },
    "componentes": {
      "type": "object",
      "properties": {
        "ecra": {
          "type": "string",
          "enum": [
            "OK",
            "AVARIADO",
            "DESCONHECIDO"
          ],
          "default": "DESCONHECIDO"
        },
        "disco": {
          "type": "string",
          "enum": [
            "OK",
            "AVARIADO",
            "DESCONHECIDO"
          ],
          "default": "DESCONHECIDO"
        },
        "ram": {
          "type": "string",
          "enum": [
            "OK",
            "AVARIADO",
            "DESCONHECIDO"
          ],
          "default": "DESCONHECIDO"
        },
        "board": {
          "type": "string",
          "enum": [
            "OK",
            "AVARIADO",
            "DESCONHECIDO"
          ],
          "default": "DESCONHECIDO"
        },
        "bateria": {
          "type": "string",
          "enum": [
            "OK",
            "AVARIADO",
            "DESCONHECIDO"
          ],
          "default": "DESCONHECIDO"
        },
        "teclado": {
          "type": "string",
          "enum": [
            "OK",
            "AVARIADO",
            "DESCONHECIDO"
          ],
          "default": "DESCONHECIDO"
        },
        "touchpad": {
          "type": "string",
          "enum": [
            "OK",
            "AVARIADO",
            "DESCONHECIDO"
          ],
          "default": "DESCONHECIDO"
        }
      }
    },
    "historico_estados": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "tipo": {
            "type": "string"
          },
          "estado_anterior": {
            "type": "string"
          },
          "estado_novo": {
            "type": "string"
          },
          "campo": {
            "type": "string"
          },
          "valor_anterior": {
            "type": "string"
          },
          "valor_novo": {
            "type": "string"
          },
          "data": {
            "type": "string"
          },
          "utilizador": {
            "type": "string"
          }
        }
      }
    },
    "documentos": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string"
          },
          "nome": {
            "type": "string"
          },
          "tipo": {
            "type": "string"
          },
          "data_upload": {
            "type": "string"
          },
          "ativo": {
            "type": "boolean"
          },
          "eliminado_por": {
            "type": "string"
          },
          "data_eliminacao": {
            "type": "string"
          }
        }
      }
    }
  },
  "required": [
    "equipamento_id",
    "origem"
  ]
}