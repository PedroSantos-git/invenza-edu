{
  "name": "Equipamento",
  "type": "object",
  "properties": {
    "numero_serie": {
      "type": "string",
      "description": "N\u00famero de s\u00e9rie do equipamento"
    },
    "numero_imobilizado": {
      "type": "string",
      "description": "N\u00famero de imobilizado"
    },
    "designacao": {
      "type": "string",
      "description": "Designa\u00e7\u00e3o/nome do equipamento"
    },
    "tipo": {
      "type": "string",
      "description": "Tipo de equipamento (livre, gerido pela tabela TipoEquipamento)"
    },
    "marca": {
      "type": "string"
    },
    "modelo": {
      "type": "string"
    },
    "estado": {
      "type": "string",
      "enum": [
        "Aluno",
        "Docente",
        "Escola",
        "Extraviado",
        "Inutilizado",
        "Manutenção",
        "Rececionado",
        "Recondicionamento",
        "Recuperável",
        "Substituido"
      ],
      "default": "Rececionado"
    },
    "situacao_armazem": {
      "type": "string",
      "enum": [
        "Desconhecido",
        "Em armazém",
        "Fora de armazém"
      ],
      "default": "Desconhecido"
    },
    "historico_armazem": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "data": { "type": "string", "format": "date-time" },
          "tipo": { "type": "string", "enum": ["ENTRADA", "SAÍDA"] },
          "utilizador": { "type": "string" }
        }
      },
      "default": []
    },
    "notas": {
      "type": "string"
    },
    "data_entrada": {
      "type": "string",
      "format": "date",
      "description": "Data de entrada do equipamento"
    },
    "documentos": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string"
          },
          "nome": {
            "type": "string"
          },
          "tipo": {
            "type": "string"
          },
          "data_upload": {
            "type": "string"
          },
          "ativo": {
            "type": "boolean"
          },
          "eliminado_por": {
            "type": "string"
          },
          "data_eliminacao": {
            "type": "string"
          }
        }
      }
    }
  },
  "required": [
    "numero_serie",
    "designacao",
    "tipo"
  ]
}